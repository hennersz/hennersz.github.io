---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const projects = await getCollection('projects');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="Projects by Henry Mortimer" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			{
				projects.map((project) => (
					<div class="project">
						<h3>
							<a href={`/projects/${project.id}/`}>{project.data.title}</a>
						</h3>
						<p class="summary">{project.data.summary}</p>
						{project.data.status && <span class="status">{project.data.status}</span>}
					</div>
				))
			}
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		padding-left: 15vw;
		padding-right: 15vw;
		padding-top: 2em;
	}
	@media (max-width: 800px) {
		main {
			padding-left: 5vw;
			padding-right: 5vw;
		}
	}
	.project {
		margin-bottom: 2em;
	}
	.project h3 {
		margin-bottom: 0.1em;
	}
	.project a {
		text-decoration: none;
	}
	.project a:hover {
		color: #ee005b;
	}
	.summary {
		color: #3b4b5e;
		margin-bottom: 0.25em;
	}
	.status {
		font-size: 0.85em;
		color: #8e8e8e;
	}
</style>
